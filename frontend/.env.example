# Citrea testnet — set after `npm run deploy:testnet` from repo root
NEXT_PUBLIC_CONTRACT_ADDRESS=0x39c281de3c95D0D3F150dA80DCAe6D63134b2c38

# Optional: custom RPC for Next.js API routes (server reads). Defaults to Citrea testnet public RPC.
# CITREA_RPC_URL=https://rpc.testnet.citrea.xyz

# Fees in wei (must match deployed contract)
NEXT_PUBLIC_CONFESSION_FEE=1000000000000000
NEXT_PUBLIC_UNLOCK_FEE=500000000000000
